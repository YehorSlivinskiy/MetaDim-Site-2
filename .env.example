# Copy to .env.local and fill in. .env.local is gitignored.
# Vercel: paste the same values into Project Settings → Environment Variables.

# ─── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Telegram bot for contact form notifications (required) ───────────────────
# Create a bot via @BotFather, take TELEGRAM_BOT_TOKEN.
# Add the bot to your team chat or channel, take the chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Site URL (required for SEO: OG, sitemap, canonical) ──────────────────────
# Production: https://metadim.ua
# Vercel preview: leave empty — falls back to seo.ts default
NEXT_PUBLIC_SITE_URL=https://metadim.ua

# ─── Upstash Redis for /api/contact rate limit (recommended) ──────────────────
# Free tier at https://upstash.com → create Redis database → REST tab
# If empty, rate limiting is disabled (unsafe for production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Resend for transactional email (recommended) ─────────────────────────────
# Free 100/day at https://resend.com.
# RESEND_FROM_EMAIL must be a verified domain or onboarding@resend.dev for testing.
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@metadim.ua

# ─── Plausible analytics (optional) ───────────────────────────────────────────
# https://plausible.io. Set the domain you registered there (e.g. metadim.ua).
# If empty, analytics script is not loaded.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
